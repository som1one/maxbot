PROJECT_NAME=KVT Service Bot
ENV=production
TZ=Europe/Minsk

BOT_TOKEN=replace-with-max-bot-token
ADMIN_MAX_CHAT_ID=0

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password

POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=kvtservice
POSTGRES_USER=kvt
POSTGRES_PASSWORD=change-this-db-password
# DATABASE_URL=postgresql+psycopg2://kvt:change-this-db-password@db:5432/kvtservice

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=replace-with-smtp-login@example.com
SMTP_PASSWORD=replace-with-smtp-password
GMAIL_APP_PASSWORD=
SMTP_FROM=replace-with-smtp-login@example.com
DEFAULT_NOTIFICATION_EMAIL=ops@example.com
EMAIL_ENABLED=true
STARTUP_EMAIL_TEST=false
RESEND_API_KEY=

CORS_ORIGINS=["*"]
BACKEND_PORT=8000
